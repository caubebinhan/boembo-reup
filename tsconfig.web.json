{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/core/**/*",
    "src/workflows/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@workflows/*": [
        "src/workflows/*"
      ],
      "@main/*": [
        "src/main/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@nodes/*": [
        "src/nodes/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    }
  }
}