{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/core/**/*",
    "src/nodes/**/*",
    "src/workflows/**/*",
    "src/renderer/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@main/*": [
        "src/main/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@nodes/*": [
        "src/nodes/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@renderer/*": [
        "src/renderer/*"
      ]
    },
    "types": [
      "electron-vite/node"
    ]
  }
}