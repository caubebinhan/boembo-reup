# =========================
# Production error reporting
# =========================
# Main process prefers SENTRY_PRODUCTION_DSN, then VITE_SENTRY_DSN_PRODUCTION, then VITE_SENTRY_DSN.
# Renderer process prefers VITE_SENTRY_DSN_PRODUCTION, then VITE_SENTRY_DSN.
SENTRY_PRODUCTION_DSN=
VITE_SENTRY_DSN_PRODUCTION=
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
VITE_SENTRY_ENVIRONMENT=production

# =====================================
# Debug tab -> staging send + verification
# =====================================
# Sent by troubleshooting "Send To Sentry" action.
SENTRY_STAGING_DSN=
SENTRY_STAGING_AUTH_TOKEN=
SENTRY_STAGING_ORG=
SENTRY_STAGING_PROJECT=
SENTRY_STAGING_BASE_URL=https://sentry.io
SENTRY_STAGING_VERIFY_REQUIRED=1
SENTRY_STAGING_VERIFY_TIMEOUT_MS=45000
SENTRY_STAGING_VERIFY_POLL_MS=2500

# =====================
# Optional legacy fallback
# =====================
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_BASE_URL=https://sentry.io
SENTRY_VERIFY_REQUIRED=0
SENTRY_VERIFY_TIMEOUT_MS=45000
SENTRY_VERIFY_POLL_MS=2500

# =====================
# Test runner options
# =====================
E2E_HEADLESS=1
TEST_CASE_ID=
UNIT_CASE_ID=

# =====================
# Optional Sentry OAuth connect (in-app button)
# =====================
# Device-flow client id from your Sentry integration/app setup
SENTRY_OAUTH_CLIENT_ID=
SENTRY_OAUTH_SCOPE=org:read project:read event:read
SENTRY_OAUTH_BASE_URL=https://sentry.io
SENTRY_OAUTH_ORG_HINT=
